# Databricks workspace configuration
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<your-token>

# LLM endpoint
LLM_ENDPOINT_NAME=databricks-claude-3-7-sonnet

# Unity Catalog tools (comma-separated function patterns)
UC_TOOL_NAMES=main_build.dbdemos_ai_agent.*

# Vector Search (leave empty to disable)
VECTOR_SEARCH_INDEX=
VECTOR_SEARCH_ENDPOINT_NAME=dbdemos_vs_endpoint

# MCP server URLs (comma-separated, leave empty to disable)
MCP_SERVER_URLS=

# Lakebase for long-term memory (use EITHER instance name OR autoscaling project+branch)
LAKEBASE_INSTANCE_NAME=
LAKEBASE_AUTOSCALING_PROJECT=<your-project-name>
LAKEBASE_AUTOSCALING_BRANCH=<your-branch-name>

# Embedding config for memory semantic search
EMBEDDING_ENDPOINT=databricks-gte-large-en
EMBEDDING_DIMS=1024

# MLflow
MLFLOW_TRACKING_URI=databricks
